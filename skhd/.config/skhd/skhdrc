# open terminal
alt - return : open -na /Applications/Alacritty.app

# close window
#cmd - c : yabai -m window --close

# open web browser
ctrl + shift - 1 : open -na /Applications/Firefox.app
# open vifm
ctrl + shift - 2 : /Applications/Alacritty.app/Contents/MacOS/alacritty -e vifm
# open music
ctrl + shift - 3 : open -na /System/Applications/Music.app

# focus window
alt - l : yabai -m window --focus next
alt - h : yabai -m window --focus prev

# swap managed window
alt - return : yabai -m window --swap west

# move managed window
# shift + cmd - h : yabai -m window --warp east

# create / destroy space
alt + shift - n : yabai -m space --create
alt + shift - m : yabai -m space --destroy

# move window to space
alt + shift - 1 : yabai -m window --space 2 && yabai -m space --focus 2
alt + shift - 2 : yabai -m window --space 3 && yabai -m space --focus 3
alt + shift - 3 : yabai -m window --space 4 && yabai -m space --focus 4
alt + shift - 4 : yabai -m window --space 5 && yabai -m space --focus 5
alt + shift - 5 : yabai -m window --space 6 && yabai -m space --focus 6
alt + shift - 6 : yabai -m window --space 7 && yabai -m space --focus 7
alt + shift - 7 : yabai -m window --space 8 && yabai -m space --focus 8
alt + shift - 8 : yabai -m window --space 9 && yabai -m space --focus 9
alt + shift - 9 : yabai -m window --space 10 && yabai -m space --focus 10

# fast focus desktop
alt - tab : yabai -m space --focus next || yabai -m space --focus first
alt + shift - tab : yabai -m space --focus prev || yabai -m space --focus last

alt - 1 : yabai -m space --focus 2
alt - 2 : yabai -m space --focus 3
alt - 3 : yabai -m space --focus 4
alt - 4 : yabai -m space --focus 5
alt - 5 : yabai -m space --focus 6
alt - 6 : yabai -m space --focus 7
alt - 7 : yabai -m space --focus 8
alt - 8 : yabai -m space --focus 9
alt - 9 : yabai -m space --focus 10

# send window to desktop and follow focus
# shift + cmd - z : yabai -m window --space next; yabai -m space --focus next
# shift + cmd - 2 : yabai -m window --space  2; yabai -m space --focus 2

# focus monitor
alt - 0x2B : yabai -m display --focus prev
alt - 0x2F : yabai -m display --focus next

# send window to monitor and follow focus
alt + shift - 0x2B  : yabai -m window --display prev; yabai -m display --focus prev
alt + shift - 0x2F  : yabai -m window --display next; yabai -m display --focus next

# move floating window
# shift + ctrl - a : yabai -m window --move rel:-20:0
# shift + ctrl - s : yabai -m window --move rel:0:20

# increase window size
 alt + shift - h : yabai -m window --resize left:-20:0
 alt + shift - l : yabai -m window --resize right:20:0
#shift + alt - w : yabai -m window --resize top:0:-20

# decrease window size
# shift + cmd - s : yabai -m window --resize bottom:0:-20
# shift + cmd - w : yabai -m window --resize top:0:20

# set insertion point in focused container
# ctrl + alt - h : yabai -m window --insert west

# toggle window zoom
# alt - d : yabai -m window --toggle zoom-parent
# alt - f : yabai -m window --toggle zoom-fullscreen

# toggle window split type
 alt - e : yabai -m window --toggle split

# float / unfloat window and center on screen
 alt - t : yabai -m window --toggle float;\
           yabai -m window --grid 4:4:1:1:2:2

# toggle sticky(+float), topmost, picture-in-picture
# alt - p : yabai -m window --toggle sticky;\
#           yabai -m window --toggle topmost;\
#           yabai -m window --toggle pip
